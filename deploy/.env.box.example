# Copy to deploy/.env.box and fill real values. NEVER commit .env.box.
# ON-SITE box config for the PULL-from-GHCR stack (docker-compose.box.yml).
#
# Unlike the build-on-box flow, frontend images are PREBUILT in CI and are
# install-agnostic: the WS URL is derived from the page origin at runtime, so
# changing BOX_HOST here does NOT require rebuilding anything — just restart.

# The box's LAN address (IP or hostname). Devices reach the system at
# http://<BOX_HOST>/ . Used for ALLOWED_HOSTS / CORS only now.
BOX_HOST=192.168.0.127

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.0.127
CORS_ALLOWED_ORIGINS=http://192.168.0.127

# Postgres (local box DB — independent from the cloud)
POSTGRES_USER=queue
POSTGRES_PASSWORD=change-me
POSTGRES_DB=queue_system
DATABASE_URL=postgres://queue:change-me@db:5432/queue_system

# Redis (channel layer)
REDIS_URL=redis://redis:6379/0

# Seed once on first boot (set to 1, start, then back to 0). After that the
# catalog stays current via the sync_worker pulling from the cloud.
SEED_ON_START=1

# ---- Local-first sync ----
SYNC_ROLE=local
CLOUD_URL=https://nmpi.avtoxizmet.uz
SYNC_TOKEN=change-me-to-match-the-cloud
SYNC_INTERVAL=15
SYNC_BACKOFF_MAX=300

# Where docker login stored GHCR creds (so watchtower can pull private images).
# Default ~/.docker is fine; override if your docker config lives elsewhere.
DOCKER_CONFIG=~/.docker
