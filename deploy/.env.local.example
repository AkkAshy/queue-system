# Copy to deploy/.env.local and fill real values. NEVER commit .env.local.
# This is the ON-SITE box config (Phase A, local-first). HTTP on the LAN.

# The box's LAN address (IP or hostname) — devices reach the system at
# http://<BOX_HOST>/ , and frontends bake this into their WS URL at build time.
# Rebuild the frontends if this changes.
BOX_HOST=192.168.1.50

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
# Allow the box host + localhost; add the LAN IP/hostname.
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.50
CORS_ALLOWED_ORIGINS=http://192.168.1.50

# Postgres (local box DB — independent from the cloud)
POSTGRES_USER=queue
POSTGRES_PASSWORD=change-me
POSTGRES_DB=queue_system
DATABASE_URL=postgres://queue:change-me@db:5432/queue_system

# Redis (channel layer)
REDIS_URL=redis://redis:6379/0

# Seed once on first boot (set to 1 once, then back to 0). After that the
# catalog is kept current by the sync_worker pulling from the cloud.
SEED_ON_START=1

# ---- Local-first sync (Phase D) ----
# This box is a LOCAL node: it pulls the catalog from CLOUD_URL and pushes
# events up. SYNC_TOKEN must match the cloud's SYNC_TOKEN.
SYNC_ROLE=local
CLOUD_URL=https://nmpi.avtoxizmet.uz
SYNC_TOKEN=change-me-to-match-the-cloud
SYNC_INTERVAL=15
SYNC_BACKOFF_MAX=300
