# Copy to deploy/.env.prod and fill real values. NEVER commit .env.prod.
# Base domain (subdomains queue./admin./operator./tablo. are derived).
DOMAIN=ndpi.uz

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=queue.ndpi.uz,admin.ndpi.uz,operator.ndpi.uz,tablo.ndpi.uz
CORS_ALLOWED_ORIGINS=https://queue.ndpi.uz,https://admin.ndpi.uz,https://operator.ndpi.uz,https://tablo.ndpi.uz

# Postgres (used by the db service and the backend DATABASE_URL)
POSTGRES_USER=queue
POSTGRES_PASSWORD=change-me
POSTGRES_DB=queue_system
DATABASE_URL=postgres://queue:change-me@db:5432/queue_system

# Redis (channel layer)
REDIS_URL=redis://redis:6379/0

# Seed fixtures on first backend start (set to 1 once, then back to 0)
SEED_ON_START=1
