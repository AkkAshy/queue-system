{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NDPI Operator",
  "version": "0.1.0",
  "identifier": "kz.ndpi.operator",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "NDPI · Pult",
        "width": 360,
        "height": 600,
        "minWidth": 320,
        "minHeight": 480,
        "alwaysOnTop": true,
        "resizable": true,
        "decorations": true,
        "center": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
